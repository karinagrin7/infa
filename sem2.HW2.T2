s = input()
t = '#' + '#'.join(s) + '#'
n = len(t)
p = [0] * n
l = 0
r = 0
a = 0
for i in range(n):
    j = l + r - i
    if i < r:
        p[i] = min(r - i, p[j])
    while i - p[i] - 1 >= 0 and i + p[i] + 1 < n and t[i - p[i] - 1] == t[i + p[i] + 1]:
        p[i] += 1
    if i + p[i] > r:
        l = i - p[i]
        r = i + p[i]
    a += (p[i] + 1) // 2
print(a)
